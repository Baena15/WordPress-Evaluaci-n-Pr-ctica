[{"id": "702517e", "elType": "container", "settings": {"classes": {"$$type": "classes", "value": ["e-588726d"]}}, "elements": [{"id": "880cdac", "elType": "widget", "widgetType": "html", "settings": {"html": "\n\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n.uf-page { font-family: 'Inter', system-ui, sans-serif; color: #18181b; }\n.uf-page h1, .uf-page h2, .uf-page h3 { font-family: 'Oswald', sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: -0.02em; margin: 0 0 16px; }\n.uf-page p { margin: 0; line-height: 1.7; }\n.uf-page a { text-decoration: none; color: inherit; }\n</style>\n\n<div class=\"uf-page\">\n\n<div style=\"position: relative; background: linear-gradient(rgba(15,15,17,0.80), rgba(15,15,17,0.65)), url('/assets/images/gym-equipment.jpg') center/cover no-repeat; color: #fff; min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 100px 24px; box-sizing: border-box;\">\n  <div style=\"max-width: 900px;\">\n    <p style=\"font-size: 0.9em; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #ff6b35; margin-bottom: 16px;\">UrbanFit Gym</p>\n    <h1 style=\"font-size: clamp(40px, 7vw, 72px); line-height: 1.05; margin-bottom: 20px; color: #fff;\">Servicios</h1>\n    <p style=\"font-size: 1.15em; color: rgba(255,255,255,0.85); max-width: 640px; margin: 0 auto; font-weight: 400;\">Todo lo que necesitas para entrenar, mejorar y cuidar de ti.</p>\n  </div>\n</div>\n\n\n<div style=\"max-width: 1200px; margin: 0 auto; padding: 90px 24px;\">\n  \n<div style=\"text-align: center; margin-bottom: 50px;\">\n  <p style=\"font-size: 0.85em; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #ff6b35; margin-bottom: 10px;\">Qué ofrecemos</p>\n  <h2 style=\"font-size: clamp(32px, 5vw, 48px); color: #18181b;\">Entrenamiento sin límites</h2>\n</div>\n\n  <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;\">\n    \n      <div style=\"background: #fff; padding: 40px 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); transition: transform .2s;\">\n        <div style=\"margin-bottom: 20px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M6.5 6.5l11 11\"/><path d=\"M21 21l-1-1\"/><path d=\"M3 3l1 1\"/><path d=\"M18 22l4-4\"/><path d=\"M2 6l4-4\"/><path d=\"M3 10l4-4\"/><path d=\"M14 21l4-4\"/></svg></div>\n        <h3 style=\"font-size: 1.3rem; margin-bottom: 12px;\">Sala de musculación</h3>\n        <p style=\"color: #4b5563;\">Máquinas de última generación, mancuernas, barras y zona de peso libre. Todo lo que necesitas para ganar fuerza y tono muscular.</p>\n      </div>\n\n\n      <div style=\"background: #fff; padding: 40px 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); transition: transform .2s;\">\n        <div style=\"margin-bottom: 20px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"5.5\" cy=\"17.5\" r=\"3.5\"/><circle cx=\"18.5\" cy=\"17.5\" r=\"3.5\"/><path d=\"M15 6a1 1 0 1 0 0-2 1 1 0 0 0 0 2zm-3 11.5V14l-3-3 4-3 2 3h2\"/><path d=\"M8 14.5v.5\"/></svg></div>\n        <h3 style=\"font-size: 1.3rem; margin-bottom: 12px;\">Clases dirigidas</h3>\n        <p style=\"color: #4b5563;\">Spinning, body pump, yoga, pilates y HIIT. Horarios de mañana y tarde para adaptarnos a tu rutina.</p>\n      </div>\n\n\n      <div style=\"background: #fff; padding: 40px 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); transition: transform .2s;\">\n        <div style=\"margin-bottom: 20px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/></svg></div>\n        <h3 style=\"font-size: 1.3rem; margin-bottom: 12px;\">Entrenamiento personal</h3>\n        <p style=\"color: #4b5563;\">Evaluación inicial, planificación periódica y seguimiento cercano con entrenadores certificados.</p>\n      </div>\n\n\n      <div style=\"background: #fff; padding: 40px 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); transition: transform .2s;\">\n        <div style=\"margin-bottom: 20px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M3 3v18h18\"/><path d=\"M18 17V9\"/><path d=\"M13 17V5\"/><path d=\"M8 17v-3\"/></svg></div>\n        <h3 style=\"font-size: 1.3rem; margin-bottom: 12px;\">Valoración física</h3>\n        <p style=\"color: #4b5563;\">Mediciones, test de condición física y análisis de composición corporal para diseñar tu plan ideal.</p>\n      </div>\n\n\n      <div style=\"background: #fff; padding: 40px 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); transition: transform .2s;\">\n        <div style=\"margin-bottom: 20px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 20.94c1.5 0 2.75 1.06 4 1.06 3 0 6-8 6-12.22A4.91 4.91 0 0 0 17 5c-2.22 0-4 1.44-5 2-1-.56-2.78-2-5-2a4.9 4.9 0 0 0-5 4.78C2 14 5 22 8 22c1.25 0 2.5-1.06 4-1.06Z\"/><path d=\"M10 2c1 .5 2 2 2 5\"/></svg></div>\n        <h3 style=\"font-size: 1.3rem; margin-bottom: 12px;\">Asesoramiento nutricional</h3>\n        <p style=\"color: #4b5563;\">Complementa tu entrenamiento con pautas nutricionales personalizadas de la mano de nuestros expertos.</p>\n      </div>\n\n\n      <div style=\"background: #fff; padding: 40px 30px; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); transition: transform .2s;\">\n        <div style=\"margin-bottom: 20px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z\"/></svg></div>\n        <h3 style=\"font-size: 1.3rem; margin-bottom: 12px;\">Zona de bienestar</h3>\n        <p style=\"color: #4b5563;\">Relájate después de entrenar en nuestra zona de estiramientos, recuperación activa y saunas.</p>\n      </div>\n\n  </div>\n</div>\n\n<div style=\"background: #f3f4f6; padding: 90px 24px;\">\n  <div style=\"max-width: 1200px; margin: 0 auto;\">\n    <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 60px; align-items: center;\">\n      <div style=\"border-radius: 12px; overflow: hidden; box-shadow: 0 20px 40px rgba(0,0,0,0.12);\">\n        <img src=\"/assets/images/group-class.jpg\" alt=\"Clases dirigidas en UrbanFit Gym\" style=\"width: 100%; height: auto; display: block;\">\n      </div>\n      <div>\n        <p style=\"font-size: 0.85em; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #ff6b35; margin-bottom: 10px;\">Por qué elegirnos</p>\n        <h2 style=\"font-size: clamp(28px, 4vw, 40px); margin-bottom: 24px;\">Entrena a tu ritmo, con el mejor equipo</h2>\n        <ul style=\"list-style: none; padding: 0; margin: 0;\">\n          \n        <li style=\"display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; color: #374151;\">\n          <span style=\"flex-shrink: 0;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n          <span style=\"font-weight: 500;\">Más de 45 clases semanales</span>\n        </li>\n\n\n        <li style=\"display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; color: #374151;\">\n          <span style=\"flex-shrink: 0;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n          <span style=\"font-weight: 500;\">Entrenadores certificados</span>\n        </li>\n\n\n        <li style=\"display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; color: #374151;\">\n          <span style=\"flex-shrink: 0;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n          <span style=\"font-weight: 500;\">Instalaciones renovadas en 2024</span>\n        </li>\n\n\n        <li style=\"display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; color: #374151;\">\n          <span style=\"flex-shrink: 0;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg></span>\n          <span style=\"font-weight: 500;\">Horario flexible de 06:00 a 23:00</span>\n        </li>\n\n        </ul>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div style=\"max-width: 1100px; margin: 0 auto; padding: 90px 24px; text-align: center;\">\n  <p style=\"font-size: 0.85em; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #ff6b35; margin-bottom: 10px;\">Planes</p>\n  <h2 style=\"font-size: clamp(32px, 5vw, 48px); margin-bottom: 40px;\">Empieza hoy</h2>\n  <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 30px;\">\n    <div style=\"background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 40px 30px;\">\n      <h3 style=\"font-size: 1.2rem; color: #6b7280;\">Básico</h3>\n      <p style=\"font-size: 2.5rem; font-family: 'Oswald', sans-serif; font-weight: 700; color: #18181b; margin: 16px 0;\">29€<span style=\"font-size: 1rem; font-family: 'Inter', sans-serif; font-weight: 400; color: #6b7280;\">/mes</span></p>\n      <p style=\"color: #4b5563; margin-bottom: 24px;\">Acceso a sala de musculación y zona cardio en horario completo.</p>\n      <a href=\"/contacto/\" style=\"display: inline-block; border: 2px solid #18181b; color: #18181b; padding: 14px 28px; border-radius: 4px; font-weight: 700; text-transform: uppercase; font-size: 0.9rem;\">Elegir plan</a>\n    </div>\n    <div style=\"background: #18181b; color: #fff; border-radius: 12px; padding: 50px 30px; transform: scale(1.03); box-shadow: 0 20px 40px rgba(0,0,0,0.2);\">\n      <h3 style=\"font-size: 1.2rem; color: #ff6b35;\">Premium</h3>\n      <p style=\"font-size: 2.5rem; font-family: 'Oswald', sans-serif; font-weight: 700; margin: 16px 0;\">49€<span style=\"font-size: 1rem; font-family: 'Inter', sans-serif; font-weight: 400; color: #9ca3af;\">/mes</span></p>\n      <p style=\"color: #d1d5db; margin-bottom: 24px;\">Todo lo del plan Básico + clases dirigidas ilimitadas y valoración física.</p>\n      <a href=\"/contacto/\" style=\"display: inline-block; background: #ff6b35; color: #fff; padding: 14px 28px; border-radius: 4px; font-weight: 700; text-transform: uppercase; font-size: 0.9rem;\">Elegir plan</a>\n    </div>\n    <div style=\"background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 40px 30px;\">\n      <h3 style=\"font-size: 1.2rem; color: #6b7280;\">Elite</h3>\n      <p style=\"font-size: 2.5rem; font-family: 'Oswald', sans-serif; font-weight: 700; color: #18181b; margin: 16px 0;\">79€<span style=\"font-size: 1rem; font-family: 'Inter', sans-serif; font-weight: 400; color: #6b7280;\">/mes</span></p>\n      <p style=\"color: #4b5563; margin-bottom: 24px;\">Incluye 4 sesiones de entrenamiento personal y asesoramiento nutricional.</p>\n      <a href=\"/contacto/\" style=\"display: inline-block; border: 2px solid #18181b; color: #18181b; padding: 14px 28px; border-radius: 4px; font-weight: 700; text-transform: uppercase; font-size: 0.9rem;\">Elegir plan</a>\n    </div>\n  </div>\n</div>\n\n\n<div style=\"background: #ff6b35; color: #fff; text-align: center; padding: 80px 24px;\">\n  <div style=\"max-width: 800px; margin: 0 auto;\">\n    <h2 style=\"font-size: clamp(32px, 5vw, 48px); margin-bottom: 16px; color: #fff;\">¿Listo para empezar?</h2>\n    <p style=\"font-size: 1.15em; margin-bottom: 32px; color: rgba(255,255,255,0.95);\">Únete hoy a UrbanFit Gym y da el primer paso hacia una vida más saludable.</p>\n    <a href=\"/contacto/\" style=\"display: inline-block; background: #18181b; color: #fff; padding: 18px 40px; border-radius: 4px; font-weight: 700; font-size: 1rem; letter-spacing: 0.05em; text-transform: uppercase;\">Contacta con nosotros</a>\n  </div>\n</div>\n\n</div>\n"}}]}]