[{"id": "702517e", "elType": "e-flexbox", "settings": {"classes": {"$$type": "classes", "value": ["e-588726d"]}}, "elements": [{"id": "880cdac", "elType": "widget", "widgetType": "html", "settings": {"html": "\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Oswald:wght@500;600;700&display=swap\" rel=\"stylesheet\">\n<style>\n.uf-page { font-family: 'Inter', system-ui, sans-serif; color: #18181b; }\n.uf-page h1, .uf-page h2, .uf-page h3 { font-family: 'Oswald', sans-serif; font-weight: 700; text-transform: uppercase; letter-spacing: -0.02em; margin: 0 0 16px; }\n.uf-page p { margin: 0; line-height: 1.7; }\n</style>\n\n<div class=\"uf-page\">\n\n<!-- Hero -->\n<div style=\"position: relative; background: linear-gradient(rgba(15,15,17,0.82), rgba(15,15,17,0.70)), url('/assets/images/hero-gym.jpg') center/cover no-repeat; color: #fff; min-height: 95vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 120px 24px; box-sizing: border-box;\">\n  <div style=\"max-width: 900px;\">\n    <p style=\"font-size: 0.95em; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: #ff6b35; margin-bottom: 16px;\">UrbanFit Gym</p>\n    <h1 style=\"font-size: clamp(48px, 8vw, 84px); line-height: 1.0; margin-bottom: 24px; color: #fff;\">Transforma tu cuerpo.<br>Supera tus límites.</h1>\n    <p style=\"font-size: 1.25em; color: rgba(255,255,255,0.85); max-width: 640px; margin: 0 auto 40px; font-weight: 400;\">Entrena con equipamiento profesional, entrenadores certificados y una comunidad que te impulsa a dar lo mejor de ti.</p>\n    <div style=\"display: flex; flex-wrap: wrap; gap: 16px; justify-content: center;\">\n      <a href=\"/contacto/\" style=\"display: inline-block; background: #ff6b35; color: #fff; padding: 18px 36px; text-decoration: none; border-radius: 4px; font-weight: 700; font-size: 1rem; letter-spacing: 0.05em; text-transform: uppercase; transition: transform .2s;\">Empezar ahora</a>\n      <a href=\"/servicios/\" style=\"display: inline-block; background: transparent; color: #fff; padding: 18px 36px; text-decoration: none; border-radius: 4px; font-weight: 700; font-size: 1rem; letter-spacing: 0.05em; text-transform: uppercase; border: 2px solid rgba(255,255,255,0.4); transition: background .2s;\">Ver servicios</a>\n    </div>\n  </div>\n</div>\n\n<!-- Stats -->\n<div style=\"background: #0f0f11; color: #fff; padding: 80px 24px; box-sizing: border-box;\">\n  <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 40px; max-width: 1200px; margin: 0 auto; text-align: center;\">\n    <div>\n      <p style=\"font-family: 'Oswald', sans-serif; font-size: 3.5em; font-weight: 700; color: #ff6b35; line-height: 1;\">8+</p>\n      <p style=\"color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85em; margin-top: 8px;\">Años de experiencia</p>\n    </div>\n    <div>\n      <p style=\"font-family: 'Oswald', sans-serif; font-size: 3.5em; font-weight: 700; color: #ff6b35; line-height: 1;\">1.200+</p>\n      <p style=\"color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85em; margin-top: 8px;\">Socios activos</p>\n    </div>\n    <div>\n      <p style=\"font-family: 'Oswald', sans-serif; font-size: 3.5em; font-weight: 700; color: #ff6b35; line-height: 1;\">45+</p>\n      <p style=\"color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85em; margin-top: 8px;\">Clases semanales</p>\n    </div>\n    <div>\n      <p style=\"font-family: 'Oswald', sans-serif; font-size: 3.5em; font-weight: 700; color: #ff6b35; line-height: 1;\">15</p>\n      <p style=\"color: rgba(255,255,255,0.7); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.85em; margin-top: 8px;\">Entrenadores</p>\n    </div>\n  </div>\n</div>\n\n<!-- Servicios -->\n<div style=\"background: #f4f4f5; padding: 100px 24px; box-sizing: border-box;\">\n  <div style=\"max-width: 1200px; margin: 0 auto;\">\n    <p style=\"text-align: center; color: #ff6b35; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; font-size: 0.85em; margin-bottom: 12px;\">Nuestros servicios</p>\n    <h2 style=\"text-align: center; font-size: clamp(32px, 5vw, 48px); margin-bottom: 60px; color: #18181b;\">Todo para tu entrenamiento</h2>\n    <div style=\"display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 28px;\">\n      <div style=\"background: #fff; padding: 48px 32px; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); text-align: center;\">\n        <div style=\"margin-bottom: 24px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M6.5 6.5l11 11\"/><path d=\"M21 21l-1-1\"/><path d=\"M3 3l1 1\"/><path d=\"M18 22l4-4\"/><path d=\"M2 6l4-4\"/><path d=\"M3 10l4-4\"/><path d=\"M14 21l4-4\"/><path d=\"M16 3l-4 4\"/><path d=\"M6 16l-4 4\"/></svg></div>\n        <h3 style=\"font-size: 1.4em; margin-bottom: 12px;\">Sala de musculación</h3>\n        <p style=\"color: #52525b;\">Máquinas y pesos libres de última generación para entrenar todos los grupos musculares con seguridad.</p>\n      </div>\n      <div style=\"background: #fff; padding: 48px 32px; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); text-align: center;\">\n        <div style=\"margin-bottom: 24px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M18 8h1a4 4 0 0 1 0 8h-1\"/><path d=\"M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z\"/><line x1=\"6\" y1=\"2\" x2=\"6\" y2=\"4\"/><line x1=\"10\" y1=\"2\" x2=\"10\" y2=\"4\"/><line x1=\"14\" y1=\"2\" x2=\"14\" y2=\"4\"/></svg></div>\n        <h3 style=\"font-size: 1.4em; margin-bottom: 12px;\">Clases dirigidas</h3>\n        <p style=\"color: #52525b;\">Spinning, HIIT, yoga, body pump y más disciplinas con monitores especializados y energía de sobra.</p>\n      </div>\n      <div style=\"background: #fff; padding: 48px 32px; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); text-align: center;\">\n        <div style=\"margin-bottom: 24px;\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"48\" height=\"48\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#ff6b35\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2\"/><circle cx=\"12\" cy=\"7\" r=\"4\"/><path d=\"M16 3.13a4 4 0 0 1 0 7.75\"/></svg></div>\n        <h3 style=\"font-size: 1.4em; margin-bottom: 12px;\">Entrenamiento personal</h3>\n        <p style=\"color: #52525b;\">Planes a medida, seguimiento de progreso y asesoramiento nutricional para alcanzar tus objetivos.</p>\n      </div>\n    </div>\n  </div>\n</div>\n\n<!-- Instalaciones -->\n<div style=\"background: #fff; padding: 100px 24px; box-sizing: border-box;\">\n  <div style=\"max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;\">\n    <div>\n      <img src=\"/assets/images/gym-floor.jpg\" alt=\"Instalaciones UrbanFit Gym\" style=\"width: 100%; height: auto; border-radius: 8px; box-shadow: 0 20px 60px rgba(0,0,0,0.12);\">\n    </div>\n    <div>\n      <p style=\"color: #ff6b35; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; font-size: 0.85em; margin-bottom: 12px;\">Instalaciones</p>\n      <h2 style=\"font-size: clamp(32px, 5vw, 48px); margin-bottom: 24px; color: #18181b;\">Espacios diseñados para rendir</h2>\n      <p style=\"color: #52525b; margin-bottom: 24px;\">Más de 800 m² distribuidos en zona de cardio, musculación, sala polivalente para clases y zona de entrenamiento funcional. Ventilación, iluminación y equipamiento pensados para que cada sesión sea cómoda y efectiva.</p>\n      <ul style=\"list-style: none; padding: 0; margin: 0; color: #18181b; font-weight: 600;\">\n        <li style=\"margin-bottom: 12px; display: flex; align-items: center; gap: 10px;\"><span style=\"color: #ff6b35;\">✓</span> Zona de cardio con vistas</li>\n        <li style=\"margin-bottom: 12px; display: flex; align-items: center; gap: 10px;\"><span style=\"color: #ff6b35;\">✓</span> Vestuarios con duchas privadas</li>\n        <li style=\"margin-bottom: 12px; display: flex; align-items: center; gap: 10px;\"><span style=\"color: #ff6b35;\">✓</span> Sala de clases con aforo limitado</li>\n        <li style=\"margin-bottom: 12px; display: flex; align-items: center; gap: 10px;\"><span style=\"color: #ff6b35;\">✓</span> Parking gratuito para socios</li>\n      </ul>\n    </div>\n  </div>\n</div>\n\n<!-- Testimonios -->\n<div style=\"background: #f4f4f5; padding: 100px 24px; box-sizing: border-box;\">\n  <div style=\"max-width: 800px; margin: 0 auto; text-align: center;\">\n    <p style=\"color: #ff6b35; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; font-size: 0.85em; margin-bottom: 12px;\">Testimonios</p>\n    <h2 style=\"font-size: clamp(32px, 5vw, 48px); margin-bottom: 50px; color: #18181b;\">Lo que dicen nuestros socios</h2>\n    <div style=\"background: #fff; padding: 56px 48px; border-radius: 8px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); position: relative;\">\n      <div style=\"font-size: 5em; line-height: 1; color: #ff6b35; opacity: 0.2; position: absolute; top: 20px; left: 30px; font-family: Georgia, serif;\">“</div>\n      <p style=\"font-size: 1.4em; font-style: italic; color: #3f3f46; line-height: 1.7; position: relative; z-index: 1;\">Llevo seis meses entrenando en UrbanFit y los resultados son increíbles. El ambiente es inmejorable, los entrenadores se implican de verdad y las instalaciones están siempre impecables.</p>\n      <p style=\"margin-top: 28px; font-weight: 700; color: #18181b;\">— María G.</p>\n    </div>\n  </div>\n</div>\n\n<!-- CTA -->\n<div style=\"background: #ff6b35; color: #fff; padding: 100px 24px; text-align: center; box-sizing: border-box;\">\n  <div style=\"max-width: 700px; margin: 0 auto;\">\n    <h2 style=\"font-size: clamp(32px, 5vw, 48px); margin-bottom: 16px; color: #fff;\">¿Listo para empezar?</h2>\n    <p style=\"font-size: 1.2em; color: rgba(255,255,255,0.95); margin-bottom: 36px;\">Únete hoy a UrbanFit Gym y da el primer paso hacia una vida más saludable.</p>\n    <a href=\"/contacto/\" style=\"display: inline-block; background: #0f0f11; color: #fff; padding: 18px 40px; text-decoration: none; border-radius: 4px; font-weight: 700; font-size: 1rem; letter-spacing: 0.05em; text-transform: uppercase; box-shadow: 0 10px 30px rgba(0,0,0,0.25); transition: transform .2s;\">Contacta con nosotros</a>\n  </div>\n</div>\n\n</div>\n"}, "elements": []}], "isInner": false, "styles": {"e-588726d": {"id": "e-588726d", "label": "local", "type": "class", "variants": [{"meta": {"breakpoint": "desktop", "state": null}, "props": {"flex-direction": {"$$type": "string", "value": "column"}}, "custom_css": null}]}}, "interactions": [], "editor_settings": [], "version": "0.0"}]